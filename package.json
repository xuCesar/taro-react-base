{
  "name": "taro-react-base",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.2.1",
  "description": "Lightweight Taro 4 + React 18 base framework with Zustand, React Query, typed cache and typed routing.",
  "scripts": {
    "build:weapp": "taro build --type weapp --env-prefix TARO_",
    "build:h5": "taro build --type h5 --env-prefix TARO_",
    "dev:weapp": "taro build --type weapp --watch --env-prefix TARO_",
    "dev:h5": "taro build --type h5 --watch --env-prefix TARO_",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.26.7",
    "@tanstack/react-query": "^5.66.0",
    "@tarojs/components": "4.0.9",
    "@tarojs/helper": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-html": "4.0.9",
    "@tarojs/plugin-platform-h5": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/react": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "lucide-react-taro": "^1.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.14.1",
    "@babel/core": "^7.26.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-react": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@tarojs/cli": "4.0.9",
    "@tarojs/plugin-mock": "^0.0.10",
    "@tarojs/taro-loader": "4.0.9",
    "@tarojs/test-utils-react": "^0.1.1",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.12",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "autoprefixer": "^10.4.20",
    "babel-plugin-import": "^1.13.8",
    "babel-preset-taro": "4.0.9",
    "eslint": "^9.20.0",
    "eslint-config-taro": "4.0.9",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mockjs": "^1.1.0",
    "postcss": "^8.5.1",
    "postcss-rem-to-responsive-pixel": "^5.1.3",
    "prettier": "^3.4.2",
    "react-refresh": "^0.16.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.7.3",
