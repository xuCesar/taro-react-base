{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "typeRoots": ["node_modules/@types"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["./src", "./types", "./config"],
  "compileOnSave": false
}
